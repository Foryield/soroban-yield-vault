# Copier vers .env.local.
# Reseau : "testnet" (defaut) ou "mainnet".
# - testnet : tous les champs ci-dessous ont des defauts publics.
# - mainnet : NEXT_PUBLIC_VAULT_ID et NEXT_PUBLIC_RPC_URL sont OBLIGATOIRES
#   (aucun defaut, fail-closed) ; Horizon defaut https://horizon.stellar.org.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_VAULT_ID=
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
